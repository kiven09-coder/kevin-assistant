# ============================================
# Kevin - Personal AI Assistant Configuration
# ============================================
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.

# ---- AI Provider API Keys ----
# Gemini (FREE): https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy-PUT-YOUR-KEY-HERE

# Claude (Paid): https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-PUT-YOUR-KEY-HERE

# ---- Kevin Access Control ----
# Required to use Kevin. Use a strong random string (24+ chars).
# Generate one: python -c "import secrets,string; print(''.join(__import__('secrets').choice(string.ascii_letters+string.digits+'!@#$%^&*') for _ in range(24)))"
KEVIN_PASSWORD=CHANGE-ME-TO-STRONG-PASSWORD

# Session signing secret (random base64 string, 32+ bytes)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
KEVIN_SESSION_SECRET=CHANGE-ME-TO-RANDOM-SECRET

# ---- Server Configuration ----
HOST=0.0.0.0
PORT=8000
